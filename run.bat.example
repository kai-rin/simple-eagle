@echo off
IF NOT EXIST "venv" (
    echo Creating virtual environment...
    python -m venv venv
)
call venv\Scripts\activate
pip install -r requirements.txt

echo Setting debug mode...
REM デバッグモードを有効にするには下記の行のコメントアウトを外してください
REM set EAGLE_DEBUG=true
set EAGLE_DEBUG=false

REM 認証パスワードを設定するには下記の行のコメントアウトを外してパスワードを変更してください
REM 未設定の場合は認証なしでアクセスできます
REM set EAGLE_AUTH_PASSWORD=your_password_here

echo Starting server...
echo Access: http://localhost:1595
python -c "import socket,qrcode;s=socket.socket(socket.AF_INET,socket.SOCK_DGRAM);s.connect(('8.8.8.8',80));ip=s.getsockname()[0];s.close();url=f'http://{ip}:1595';print(f'LAN Access: {url}');qr=qrcode.QRCode(border=1);qr.add_data(url);qr.print_ascii(invert=True)"
python -m uvicorn index:app --reload --host 0.0.0.0 --port 1595
